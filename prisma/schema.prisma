  facilityId               String   @unique @map("facility_id") @db.Uuid
  usageCount               Int      @default(0) @map("usage_count")
  uniqueUserCount          Int      @default(0) @map("unique_user_count")
  newUserCount             Int      @default(0) @map("new_user_count")
  repeatUserCount          Int      @default(0) @map("repeat_user_count")
  repeatRate               Decimal  @default(0) @map("repeat_rate") @db.Decimal(5, 2)
  newRate                  Decimal  @default(0) @map("new_rate") @db.Decimal(5, 2)
  averageUsageIntervalDays Decimal? @map("average_usage_interval_days") @db.Decimal(8, 2)
  repeatContinuationRate   Decimal? @map("repeat_continuation_rate") @db.Decimal(5, 2)
  avgUsesPerUser           Decimal? @map("avg_uses_per_user") @db.Decimal(8, 2)
  secondUseMedianDays      Decimal? @map("second_use_median_days") @db.Decimal(8, 2)
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  facility                 Facility @relation(fields: [facilityId], references: [id])

