}

model FacilityMonthlyDimensionMetric {
  id              String   @id @default(uuid()) @db.Uuid
  facilityId      String   @map("facility_id") @db.Uuid
  metricYear      Int      @map("metric_year") @db.SmallInt
  metricMonth     Int      @map("metric_month") @db.SmallInt
  dimensionType   String   @map("dimension_type") @db.VarChar(50)
  dimensionValue  String   @map("dimension_value") @db.VarChar(100)
  usageCount      Int      @default(0) @map("usage_count")
  uniqueUserCount Int      @default(0) @map("unique_user_count")
  percentage      Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  facility        Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, metricYear, metricMonth, dimensionType, dimensionValue])
  @@index([facilityId, metricYear(sort: Desc), metricMonth(sort: Desc), dimensionType])
  @@map("facility_monthly_dimension_metrics")
}

model FacilityYearlyDimensionMetric {
  id              String   @id @default(uuid()) @db.Uuid
  facilityId      String   @map("facility_id") @db.Uuid
  metricYear      Int      @map("metric_year") @db.SmallInt
  dimensionType   String   @map("dimension_type") @db.VarChar(50)
  dimensionValue  String   @map("dimension_value") @db.VarChar(100)
  usageCount      Int      @default(0) @map("usage_count")
  uniqueUserCount Int      @default(0) @map("unique_user_count")
  percentage      Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  facility        Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, metricYear, dimensionType, dimensionValue])
  @@index([facilityId, metricYear(sort: Desc), dimensionType])
  @@map("facility_yearly_dimension_metrics")
}

model FacilityCumulativeDimensionMetric {
  id              String   @id @default(uuid()) @db.Uuid
  facilityId      String   @map("facility_id") @db.Uuid
  dimensionType   String   @map("dimension_type") @db.VarChar(50)
  dimensionValue  String   @map("dimension_value") @db.VarChar(100)
  usageCount      Int      @default(0) @map("usage_count")
  uniqueUserCount Int      @default(0) @map("unique_user_count")
  percentage      Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  facility        Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, dimensionType, dimensionValue])
  @@index([facilityId, dimensionType])
  @@map("facility_cumulative_dimension_metrics")
}

model ComparisonBenchmark {
  id             String   @id @default(uuid()) @db.Uuid
  benchmarkScope String   @default("global") @map("benchmark_scope") @db.VarChar(30)
  periodType     String   @map("period_type") @db.VarChar(20)
  metricYear     Int?     @map("metric_year") @db.SmallInt
  metricMonth    Int?     @map("metric_month") @db.SmallInt
  metricKey      String   @map("metric_key") @db.VarChar(50)
  metricValue    Decimal  @map("metric_value") @db.Decimal(12, 2)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([periodType, metricYear, metricMonth, metricKey])
  @@map("comparison_benchmarks")
}

model EmailSetting {
  id                  String   @id @default(uuid()) @db.Uuid
  key                 String   @unique @db.VarChar(100)
  subject             String   @db.VarChar(255)
  bodyText            String   @map("body_text")
  bodyHtml            String?  @map("body_html")
  materialDownloadUrl String?  @map("material_download_url")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy           String?  @map("updated_by") @db.Uuid

  @@map("email_settings")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  actorRole    String?  @map("actor_role") @db.VarChar(30)
  facilityId   String?  @map("facility_id") @db.Uuid
  action       String   @db.VarChar(100)
  targetType   String   @map("target_type") @db.VarChar(100)
  targetId     String?  @map("target_id") @db.Uuid
  requestId    String?  @map("request_id") @db.VarChar(100)
  ipHash       String?  @map("ip_hash") @db.VarChar(64)
  userAgent    String?  @map("user_agent")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  actorUser    FacilityUser? @relation(fields: [actorUserId], references: [id])
  facility     Facility?     @relation(fields: [facilityId], references: [id])

  @@index([actorUserId])
  @@index([facilityId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
