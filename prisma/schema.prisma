generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Facility {
  id                    String   @id @default(uuid()) @db.Uuid
  code                  String   @unique @db.VarChar(50)
  name                  String   @db.VarChar(255)
  email                 String?  @db.VarChar(255)
  phoneEncrypted        String?  @map("phone_encrypted")
  prefecture            String?  @db.VarChar(50)
  city                  String?  @db.VarChar(100)
  addressLine1          String?  @map("address_line1") @db.VarChar(255)
  addressLine2          String?  @map("address_line2") @db.VarChar(255)
  industry              String?  @db.VarChar(100)
  desiredUnitCount      Int?     @map("desired_unit_count")
  plannedInstallationArea String? @map("planned_installation_area") @db.VarChar(255)
  status                String   @default("active") @db.VarChar(30)
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  createdBy             String?  @map("created_by") @db.Uuid
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy             String?  @map("updated_by") @db.Uuid
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz()

  users                 FacilityUser[]
  endUsers              EndUser[]
  devices               FacilityDevice[]
  usageSessions         UsageSession[]
  importBatches         FormResponseImportBatch[]
  importRows            FormResponseImportRow[]
  dailyMetrics          FacilityDailyMetric[]
  monthlyMetrics        FacilityMonthlyMetric[]
  yearlyMetrics         FacilityYearlyMetric[]
  cumulativeMetrics     FacilityCumulativeMetric?
  monthlyDimensionMetrics FacilityMonthlyDimensionMetric[]
  yearlyDimensionMetrics  FacilityYearlyDimensionMetric[]
  cumulativeDimensionMetrics FacilityCumulativeDimensionMetric[]
  auditLogs             AuditLog[]

  @@index([status])
  @@index([name])
  @@map("facilities")
}

model FacilityUser {
  id                String    @id @default(uuid()) @db.Uuid
  facilityId        String?   @map("facility_id") @db.Uuid
  role              String    @db.VarChar(30)
  email             String    @unique @db.VarChar(255)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  name              String?   @db.VarChar(255)
  isActive          Boolean   @default(true) @map("is_active")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until") @db.Timestamptz()
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz()
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdBy         String?   @map("created_by") @db.Uuid
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy         String?   @map("updated_by") @db.Uuid
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz()

  facility          Facility? @relation(fields: [facilityId], references: [id])
  passwordResetTokens PasswordResetToken[]
  importBatches     FormResponseImportBatch[]
  auditLogs         AuditLog[]

  @@index([facilityId])
  @@index([role])
  @@index([isActive])
  @@map("facility_users")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user      FacilityUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Inquiry {
  id                     String    @id @default(uuid()) @db.Uuid
  companyName            String    @map("company_name") @db.VarChar(255)
  departmentName         String?   @map("department_name") @db.VarChar(255)
  contactName            String    @map("contact_name") @db.VarChar(255)
  email                  String    @db.VarChar(255)
  phoneEncrypted         String?   @map("phone_encrypted")
  phoneLast4             String?   @map("phone_last4") @db.VarChar(4)
  facilityName           String    @map("facility_name") @db.VarChar(255)
  facilityPrefecture     String?   @map("facility_prefecture") @db.VarChar(50)
  facilityCity           String?   @map("facility_city") @db.VarChar(100)
  facilityAddress        String?   @map("facility_address") @db.VarChar(255)
  industry               String?   @db.VarChar(100)
  desiredUnitCount       Int?      @map("desired_unit_count")
  desiredInstallationArea String?  @map("desired_installation_area") @db.VarChar(255)
  desiredStartTiming     String?   @map("desired_start_timing") @db.VarChar(100)
  note                   String?
  status                 String    @default("new") @db.VarChar(30)
  source                 String    @default("website") @db.VarChar(50)
  autoReplySentAt        DateTime? @map("auto_reply_sent_at") @db.Timestamptz()
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdBy              String?   @map("created_by") @db.Uuid
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy              String?   @map("updated_by") @db.Uuid
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([email])
  @@map("inquiries")
}

model ContractApplication {
  id                     String    @id @default(uuid()) @db.Uuid
  companyName            String    @map("company_name") @db.VarChar(255)
  departmentName         String?   @map("department_name") @db.VarChar(255)
  contactName            String    @map("contact_name") @db.VarChar(255)
  email                  String    @db.VarChar(255)
  phoneEncrypted         String?   @map("phone_encrypted")
  phoneLast4             String?   @map("phone_last4") @db.VarChar(4)
  facilityName           String    @map("facility_name") @db.VarChar(255)
  facilityPrefecture     String?   @map("facility_prefecture") @db.VarChar(50)
  facilityCity           String?   @map("facility_city") @db.VarChar(100)
  facilityAddress        String?   @map("facility_address") @db.VarChar(255)
  industry               String?   @db.VarChar(100)
  desiredUnitCount       Int?      @map("desired_unit_count")
  desiredInstallationArea String?  @map("desired_installation_area") @db.VarChar(255)
  desiredStartTiming     String?   @map("desired_start_timing") @db.VarChar(100)
  note                   String?
  agreedTermsAt          DateTime  @map("agreed_terms_at") @db.Timestamptz()
  agreedPrivacyAt        DateTime  @map("agreed_privacy_at") @db.Timestamptz()
  status                 String    @default("submitted") @db.VarChar(30)
  source                 String    @default("website") @db.VarChar(50)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdBy              String?   @map("created_by") @db.Uuid
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy              String?   @map("updated_by") @db.Uuid
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([email])
  @@map("contract_applications")
}

model EndUser {
  id                   String    @id @default(uuid()) @db.Uuid
  facilityId           String    @map("facility_id") @db.Uuid
  phoneEncrypted       String    @map("phone_encrypted")
  phoneHash            String    @map("phone_hash") @db.VarChar(64)
  nickname             String?   @db.VarChar(100)
  city                 String?   @db.VarChar(100)
  birthDateEncrypted   String    @map("birth_date_encrypted")
  birthYear            Int?      @map("birth_year") @db.SmallInt
  ageBucket            String    @map("age_bucket") @db.VarChar(20)
  hasUsedBeforeAnswer  Boolean?  @map("has_used_before_answer")
  firstSeenAt          DateTime  @map("first_seen_at") @db.Timestamptz()
  lastSeenAt           DateTime  @map("last_seen_at") @db.Timestamptz()
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdBy            String?   @map("created_by") @db.Uuid
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy            String?   @map("updated_by") @db.Uuid
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz()

  facility             Facility  @relation(fields: [facilityId], references: [id])
  usageSessions        UsageSession[]

  @@unique([facilityId, phoneHash])
  @@index([facilityId])
  @@index([phoneHash])
  @@index([ageBucket])
  @@index([city])
  @@map("end_users")
}

model FacilityDevice {
  id                String    @id @default(uuid()) @db.Uuid
  facilityId        String    @map("facility_id") @db.Uuid
  externalDeviceId  String    @map("external_device_id") @db.VarChar(255)
  deviceName        String?   @map("device_name") @db.VarChar(255)
  installedLocation String?   @map("installed_location") @db.VarChar(255)
  deviceType        String    @default("hair_iron_box") @map("device_type") @db.VarChar(50)
  status            String    @default("active") @db.VarChar(30)
  installedAt       DateTime? @map("installed_at") @db.Timestamptz()
  retiredAt         DateTime? @map("retired_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdBy         String?   @map("created_by") @db.Uuid
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy         String?   @map("updated_by") @db.Uuid
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz()

  facility          Facility  @relation(fields: [facilityId], references: [id])
  usageSessions     UsageSession[]

  @@unique([facilityId, externalDeviceId])
  @@index([facilityId])
  @@index([status])
  @@map("facility_devices")
}

model UsageSession {
  id                    String    @id @default(uuid()) @db.Uuid
  facilityId            String    @map("facility_id") @db.Uuid
  endUserId             String    @map("end_user_id") @db.Uuid
  deviceId              String?   @map("device_id") @db.Uuid
  sessionStartedAt      DateTime  @map("session_started_at") @db.Timestamptz()
  sessionEndedAt        DateTime? @map("session_ended_at") @db.Timestamptz()
  sessionDurationSeconds Int?     @map("session_duration_seconds")
  isFirstUseAtFacility  Boolean   @default(false) @map("is_first_use_at_facility")
  visitPurpose          String    @map("visit_purpose") @db.VarChar(50)
  usageTrigger          String    @map("usage_trigger") @db.VarChar(50)
  usedBeforeAnswer      Boolean?  @map("used_before_answer")
  sessionSource         String    @default("onsite_form_csv") @map("session_source") @db.VarChar(50)
  rawPhoneHash          String    @map("raw_phone_hash") @db.VarChar(64)
  rawCity               String?   @map("raw_city") @db.VarChar(100)
  rawBirthDateEncrypted String?   @map("raw_birth_date_encrypted")
  rawNickname           String?   @map("raw_nickname") @db.VarChar(100)
  importRowId           String?   @map("import_row_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdBy             String?   @map("created_by") @db.Uuid
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy             String?   @map("updated_by") @db.Uuid
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz()

  facility              Facility  @relation(fields: [facilityId], references: [id])
  endUser               EndUser   @relation(fields: [endUserId], references: [id])
  device                FacilityDevice? @relation(fields: [deviceId], references: [id])
  importRow             FormResponseImportRow? @relation(fields: [importRowId], references: [id])

  @@index([facilityId])
  @@index([endUserId])
  @@index([sessionStartedAt(sort: Desc)])
  @@index([facilityId, sessionStartedAt(sort: Desc)])
  @@index([visitPurpose])
  @@index([usageTrigger])
  @@map("usage_sessions")
}

model FormResponseImportBatch {
  id          String    @id @default(uuid()) @db.Uuid
  facilityId  String    @map("facility_id") @db.Uuid
  fileName    String    @map("file_name") @db.VarChar(255)
  fileSha256  String    @map("file_sha256") @db.VarChar(64)
  totalRows   Int       @default(0) @map("total_rows")
  successRows Int       @default(0) @map("success_rows")
  failedRows  Int       @default(0) @map("failed_rows")
  status      String    @default("uploaded") @db.VarChar(30)
  importedBy  String?   @map("imported_by") @db.Uuid
  startedAt   DateTime? @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  facility    Facility  @relation(fields: [facilityId], references: [id])
  importedByUser FacilityUser? @relation(fields: [importedBy], references: [id])
  rows        FormResponseImportRow[]

  @@unique([facilityId, fileSha256])
  @@index([facilityId])
  @@index([status])
  @@map("form_response_import_batches")
}

model FormResponseImportRow {
  id                    String    @id @default(uuid()) @db.Uuid
  batchId               String    @map("batch_id") @db.Uuid
  facilityId            String    @map("facility_id") @db.Uuid
  rowNumber             Int       @map("row_number")
  sourceTimestampText   String?   @map("source_timestamp_text") @db.VarChar(100)
  phoneText             String?   @map("phone_text") @db.VarChar(50)
  usedBeforeText        String?   @map("used_before_text") @db.VarChar(50)
  nicknameText          String?   @map("nickname_text") @db.VarChar(100)
  cityText              String?   @map("city_text") @db.VarChar(100)
  birthDateText         String?   @map("birth_date_text") @db.VarChar(50)
  visitPurposeText      String?   @map("visit_purpose_text") @db.VarChar(100)
  usageTriggerText      String?   @map("usage_trigger_text") @db.VarChar(100)
  externalDeviceIdText  String?   @map("external_device_id_text") @db.VarChar(255)
  normalizedPhoneHash   String?   @map("normalized_phone_hash") @db.VarChar(64)
  normalizedTimestamp   DateTime? @map("normalized_timestamp") @db.Timestamptz()
  mappedVisitPurpose    String?   @map("mapped_visit_purpose") @db.VarChar(50)
  mappedUsageTrigger    String?   @map("mapped_usage_trigger") @db.VarChar(50)
  resultStatus          String    @default("pending") @map("result_status") @db.VarChar(30)
  errorCode             String?   @map("error_code") @db.VarChar(100)
  errorMessage          String?   @map("error_message")
  usageSessionId        String?   @map("usage_session_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  batch                 FormResponseImportBatch @relation(fields: [batchId], references: [id])
  facility              Facility @relation(fields: [facilityId], references: [id])
  usageSessions         UsageSession[]

  @@unique([batchId, rowNumber])
  @@index([batchId])
  @@index([resultStatus])
  @@index([facilityId])
  @@map("form_response_import_rows")
}

model FacilityDailyMetric {
  id                       String   @id @default(uuid()) @db.Uuid
  facilityId               String   @map("facility_id") @db.Uuid
  metricDate               DateTime @map("metric_date") @db.Date
  usageCount               Int      @default(0) @map("usage_count")
  uniqueUserCount          Int      @default(0) @map("unique_user_count")
  newUserCount             Int      @default(0) @map("new_user_count")
  repeatUserCount          Int      @default(0) @map("repeat_user_count")
  repeatRate               Decimal  @default(0) @map("repeat_rate") @db.Decimal(5, 2)
  newRate                  Decimal  @default(0) @map("new_rate") @db.Decimal(5, 2)
  averageUsageIntervalDays Decimal? @map("average_usage_interval_days") @db.Decimal(8, 2)
  repeatContinuationRate   Decimal? @map("repeat_continuation_rate") @db.Decimal(5, 2)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  facility                 Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, metricDate])
  @@index([facilityId, metricDate(sort: Desc)])
  @@map("facility_daily_metrics")
}

model FacilityMonthlyMetric {
  id                       String   @id @default(uuid()) @db.Uuid
  facilityId               String   @map("facility_id") @db.Uuid
  metricYear               Int      @map("metric_year") @db.SmallInt
  metricMonth              Int      @map("metric_month") @db.SmallInt
  usageCount               Int      @default(0) @map("usage_count")
  uniqueUserCount          Int      @default(0) @map("unique_user_count")
  newUserCount             Int      @default(0) @map("new_user_count")
  repeatUserCount          Int      @default(0) @map("repeat_user_count")
  repeatRate               Decimal  @default(0) @map("repeat_rate") @db.Decimal(5, 2)
  newRate                  Decimal  @default(0) @map("new_rate") @db.Decimal(5, 2)
  averageUsageIntervalDays Decimal? @map("average_usage_interval_days") @db.Decimal(8, 2)
  repeatContinuationRate   Decimal? @map("repeat_continuation_rate") @db.Decimal(5, 2)
  avgUsesPerUser           Decimal? @map("avg_uses_per_user") @db.Decimal(8, 2)
  secondUseMedianDays      Decimal? @map("second_use_median_days") @db.Decimal(8, 2)
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  facility                 Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, metricYear, metricMonth])
  @@index([facilityId, metricYear(sort: Desc), metricMonth(sort: Desc)])
  @@map("facility_monthly_metrics")
}

